17) Bytes module

Searching / testing (mirror strings)

Contains(b, subslice), ContainsAny(b, chars), ContainsRune(b, r)
HasPrefix(b, prefix), HasSuffix(b, suffix)
Index(b, sep), LastIndex(b, sep), IndexByte(b, c), IndexRune(b, r), IndexAny(b, chars)
Count(b, sep) — non-overlapping occurrences
Equal(a, b) — compare two byte slices (faster and clearer than == conversions)
EqualFold(a, b) — case-insensitive comparison
Compare(a, b) — returns -1, 0, or 1 (for sorting)

Splitting / joining

Split(b, sep), SplitN(b, sep, n), SplitAfter(b, sep)
Fields(b) — split on whitespace
Join(s [][]byte, sep)
Cut(b, sep) — split once, returns before, after, found (Go 1.18+)

Modifying (these return new slices)

Replace(b, old, new, n), ReplaceAll(b, old, new)
ToUpper(b), ToLower(b), Title(b) (deprecated)
Trim(b, cutset), TrimLeft, TrimRight, TrimSpace(b)
TrimPrefix(b, prefix), TrimSuffix(b, suffix)
Repeat(b, count), Map(mapping, b)

18) sort.Sort(data Interface)
sort.Stable(data Interface)
sort.IsSorted(data Interface) bool
sort.Reverse(data Interface) Interface
sort.Slice(x any, less func(i, j int) bool)
sort.SliceStable(x any, less func(i, j int) bool)
sort.SliceIsSorted(x any, less func(i, j int) bool) bool
sort.Ints(x []int)
sort.IntsAreSorted(x []int) bool
sort.Float64s(x []float64)
sort.Float64sAreSorted(x []float64) bool
sort.Strings(x []string)
sort.StringsAreSorted(x []string) bool
sort.Search(n int, f func(int) bool) int
sort.SearchInts(a []int, x int) int
sort.SearchFloat64s(a []float64, x float64) int
sort.SearchStrings(a []string, x string) int

Types

sort.Interface (interface with Len, Less, Swap)
sort.IntSlice — []int with interface methods, plus a Sort() and Search(x) method
sort.Float64Slice — []float64, likewise
sort.StringSlice — []string, likewise


18) sort interface example 
import ("fmt"
        "sort"
        )

type Human struct {
        name string
        age int
}

type ByAge []Human

func (b ByAge)Less(i,j int)bool{
        return b[i].age > b[j].age
}

func (b ByAge)Len() int{
        return len(b)
}

func (b ByAge)Swap(i,j int){
        b[i],b[j] = b[j], b[i]
}


func main(){
        sl := []Human{
                        Human{name:"Sachin1", age:1},
                        Human{name:"Sachin2", age:2},
                        Human{name:"Sachin3", age:3},
                        Human{name:"Sachin4", age:4},
                        Human{name:"Sachin5", age:5},
                        }
        sort.Sort(ByAge(sl))
        fmt.Println(sl)

}

19) Buffered channels can be read after being closed.
import "fmt"
func main(){
        ch := make(chan string, 3)
        sl := []string{"sachin","is","a"}
        for _, s := range sl {
                ch <- s
        }
        close(ch)
        for s := range ch {
                fmt.Println(s)
        }
}
