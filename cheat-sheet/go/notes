10)  This example shows when 2 channel are writing how a goroutine can read from 2 different channles with the help of select. 
import ("fmt"
        "sync"
        "time"
        "strconv")


func test1(ch chan string, wg *sync.WaitGroup){
        defer wg.Done()
        for i :=0;i<10;i++ {
                fmt.Println("Pushed1 == ",i)
                ch <- strconv.Itoa(i)
                time.Sleep(time.Millisecond)
                fmt.Println("Done Pushing1")
        }
        close(ch)
}

func test2(ch chan string, wg *sync.WaitGroup){
        defer wg.Done()
        for i :=0;i<10;i++ {
                fmt.Println("Pushed2 == ",i*10)
                ch <- strconv.Itoa(i*10)
                time.Sleep(time.Millisecond)
                fmt.Println("Done Pushing2")
        }
        close(ch)
}

func test3(ch1 chan string,ch2 chan string,  wg *sync.WaitGroup){
        defer wg.Done()
        for  ch1 != nil || ch2 != nil{
                select {
                        case str1, ok1 :=  <- ch1:
                                if !ok1 {
                                        ch1 = nil
                                        continue
                                }
                                fmt.Println("Channel1 == ",str1)
                        case str2, ok2 :=  <- ch2:
                                if !ok2 {
                                        ch2 = nil
                                        continue
                                }
                                fmt.Println("Channel2 == ",str2)
                }
        }
}

func main(){
        var wg sync.WaitGroup
        wg.Add(3)
        ch1 := make(chan string)
        ch2 := make(chan string)
        go test1(ch1, &wg)
        go test2(ch2, &wg)
        go test3(ch1, ch2, &wg)
        wg.Wait()
} 

11) how selct is used to push data on a channel
import ("fmt"
        "sync"
        "time"
        "strconv")


func test1(ch chan string, wg *sync.WaitGroup){
        num := 0
        for range(time.Second) {
                select {
                        case ch <- strconv.Itoa(num):{
                                num += 1
                        }

                }
        }
}

func test2(ch chan string, wg *sync.WaitGroup){
        for range(time.Second) {
                select {
                        case s,_ := <- ch:{
                                fmt.Println("Received == ",s)
                        }
                }
        }
}

func main(){
        var wg sync.WaitGroup
        wg.Add(2)
        ch1 := make(chan string)
        go test1(ch1, &wg)
        go test2(ch1, &wg)
        wg.Wait()
}

13) Example code how one gorouting can be cancelled by another go routine
import ("fmt"
        "sync"
        "time")


func test1(ch <-chan string, wg *sync.WaitGroup){
        defer wg.Done()
        for range(time.Tick(time.Second*3)) {
                select {
                case _, ok := <-ch:
                        if !ok  {
                                return
                        }
                        default:
                                fmt.Println("Running")
                }
        }
}

func test2(ch chan string, wg *sync.WaitGroup){
        defer wg.Done()
        time.Sleep(10 * time.Second)
        fmt.Println("Timer over closing time")
        close(ch)
}

func main(){
        var wg sync.WaitGroup
        wg.Add(2)
        ch1 := make(chan string)
        go test1(ch1, &wg)
        go test2(ch1, &wg)
        wg.Wait()
}

14) Create a pipeline of goroutines to create square of given list
import ("fmt"
        "sync"
        )


func converToChannel(sl []int, wg *sync.WaitGroup) chan int{
        ch := make(chan int)
        go func() {
                defer wg.Done()
                for _,num := range sl {
                        ch <- num
                }
                close(ch)
        }()
        return ch
}

func sq2(ch chan int, wg *sync.WaitGroup) chan int{
        nCh := make(chan int)
        go func(){
                defer wg.Done()
                for ch != nil {
                                num, ok := <- ch
                                        if ok == false {
                                                close(nCh)
                                                return
                                        }
                                        nCh <- num * num

                }
        }()
        return nCh
}

func main(){
        sl := []int{1,2,3,4,5,6,7,8}
        var wg sync.WaitGroup
        wg.Add(2)
        ch1 := converToChannel(sl, &wg)
        ch2 := sq2(ch1, &wg)
        for num := range ch2 {
                fmt.Println(num)
        }
        wg.Wait()

15) Interface examples
package main

import "fmt"

type Human struct {
        legs int
}

func (h Human) walk(){
        fmt.Println("\n Human can walk \n")
}


func (h *Human) eat(){
        fmt.Println("\n EAT \n")
}

type Animal struct {
        legs int
}

func (a Animal) walk(){
        fmt.Println("\n Animal can walk \n")
}

func (h *Animal) chew(){
        fmt.Println("\n CHEW \n")
}

type Living interface {
        walk()
}

func walk(x Living) {
        switch x.(type) {
                case *Human:{
                        fmt.Println("\n Human can Eat \n")
                }
                case *Animal:{
                        fmt.Println("\n Animal can chew \n")
                }
                case Human:{
                        fmt.Println("\n Human Value can Eat \n")
                }
                case Animal:{
                        fmt.Println("\n Animal Value can chew \n")
                }
        }
}

func main(){
        h1 := new(Human)
        a1 := new(Animal)
        h := Human{}
        a := Animal{}
        walk(h1)
        walk(a1)
        walk(h)
        walk(a)
}

16) Strings module and its functions
Searching / testing

Contains(s, substr) — does s contain substr?
ContainsAny(s, chars) — contains any char from chars?
ContainsRune(s, r) — contains rune r?
HasPrefix(s, prefix) / HasSuffix(s, suffix)
Index(s, substr) — index of first occurrence, or -1
LastIndex(s, substr) — index of last occurrence
IndexByte(s, b), IndexRune(s, r), IndexAny(s, chars)
Count(s, substr) — number of non-overlapping occurrences

Splitting / joining

Split(s, sep) — split into []string
SplitN(s, sep, n) — split into at most n pieces
SplitAfter(s, sep) — keeps the separator on each piece
Fields(s) — split on whitespace, dropping empties
Join(elems []string, sep) — opposite of split

Modifying

Replace(s, old, new, n) — replace first n (use -1 for all)
ReplaceAll(s, old, new)
ToUpper(s), ToLower(s), Title(s) (deprecated — use golang.org/x/text/cases)
Trim(s, cutset), TrimLeft, TrimRight
TrimSpace(s) — strip leading/trailing whitespace
TrimPrefix(s, prefix), TrimSuffix(s, suffix)
Repeat(s, count)
Map(func(rune) rune, s) — transform each rune

Builder:-
strings.NewReader(s)

