20)  Instead of using default use timeout in select statement.Default gives a busy waiting
import ("fmt"
        "sync"
        "time")

func test1(ch chan int, wg *sync.WaitGroup){
        defer wg.Done()
        for i := 0;i<10;i++{
                ch <- i
                time.Sleep(time.Millisecond)
        }
        close(ch)
}

func test2(ch chan int, wg *sync.WaitGroup){
        defer wg.Done()
        for ch != nil{
                select {
                        case num, ok := <- ch:
                                if ok == false {
                                        ch = nil
                                        continue
                                }
                                fmt.Println(num)
                        case <- time.After(time.Millisecond):
                                fmt.Println("Defautl")
                }
        }
}

func main(){
        var wg sync.WaitGroup
        wg.Add(2)
        ch := make(chan int)
        go test1(ch, &wg)
        go test2(ch, &wg)
        wg.Wait()
}    
